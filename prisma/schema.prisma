generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Test {
  id            String   @id @default(uuid())
  aiPrompt      String
  mbtiResult    String
  scores        Json
  rawAnswers    Int[]
  modelProvider String?
  modelName     String?
  modelVersion  String?
  agentName     String?
  temperature   Float?
  createdAt     DateTime @default(now())

  // Telemetry (Feature 1)
  questionDetails Json?
  totalRetries    Int?
  totalLatencyMs  Float?
  avgLatencyMs    Float?

  // Repeat runs (Feature 2)
  runIndex   Int?
  totalRuns  Int?

  // TruthfulQA benchmark (Feature 3)
  truthfulQA Json?

  @@index([modelProvider, modelName])
  @@index([agentName])
  @@index([mbtiResult])
  @@index([createdAt])
}
