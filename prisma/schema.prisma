generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Test {
  id         String   @id @default(uuid())
  ipAddress  String
  aiPrompt   String
  mbtiResult String
  scores     Json
  createdAt  DateTime @default(now())

  @@index([ipAddress, createdAt])
}
